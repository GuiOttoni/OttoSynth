<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib"
                    xmlns:ctl="clr-namespace:OttoSynth.UI.Controls"
                    xmlns:conv="clr-namespace:OttoSynth.UI.Converters">

    <!-- ═══ FRUTIGER AERO — deep navy, cyan/sky-blue glass ═══ -->

    <Color x:Key="ColorBackgroundPrimary">#FF080F1A</Color>
    <Color x:Key="ColorBackgroundSecondary">#FF0D1929</Color>
    <Color x:Key="ColorBackgroundPanel">#FF0A1528</Color>
    <Color x:Key="ColorBackgroundDeep">#FF040A12</Color>

    <Color x:Key="ColorAccentPrimary">#FF00C8FF</Color>      <!-- bright sky blue -->
    <Color x:Key="ColorAccentSecondary">#FF0078C8</Color>    <!-- medium blue -->
    <Color x:Key="ColorAccentTertiary">#FF00E5B0</Color>     <!-- cyan-teal alert -->
    <Color x:Key="ColorAccentAmber">#FF00D0FF</Color>        <!-- icy cyan accent -->

    <Color x:Key="ColorTextPrimary">#FFD8F0FF</Color>        <!-- ice-blue white -->
    <Color x:Key="ColorTextSecondary">#FF6AABCC</Color>      <!-- muted blue-gray -->
    <Color x:Key="ColorTextTertiary">#FF2A5A78</Color>       <!-- dim teal -->

    <Color x:Key="ColorKnobTrack">#FF0D2240</Color>
    <Color x:Key="ColorKnobActive">#FF00C8FF</Color>
    <Color x:Key="ColorWaveform">#FF00BFFF</Color>
    <Color x:Key="ColorGridLines">#FF0A1E38</Color>
    <Color x:Key="ColorBorder">#FF1A4A7A</Color>
    <Color x:Key="ColorHover">#FF0D2A4A</Color>

    <SolidColorBrush x:Key="BackgroundPrimaryBrush"   Color="{StaticResource ColorBackgroundPrimary}"/>
    <SolidColorBrush x:Key="BackgroundSecondaryBrush" Color="{StaticResource ColorBackgroundSecondary}"/>
    <SolidColorBrush x:Key="BackgroundPanelBrush"     Color="{StaticResource ColorBackgroundPanel}"/>
    <SolidColorBrush x:Key="BackgroundDeepBrush"      Color="{StaticResource ColorBackgroundDeep}"/>
    <SolidColorBrush x:Key="AccentPrimaryBrush"       Color="{StaticResource ColorAccentPrimary}"/>
    <SolidColorBrush x:Key="AccentSecondaryBrush"     Color="{StaticResource ColorAccentSecondary}"/>
    <SolidColorBrush x:Key="AccentTertiaryBrush"      Color="{StaticResource ColorAccentTertiary}"/>
    <SolidColorBrush x:Key="AccentAmberBrush"         Color="{StaticResource ColorAccentAmber}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush"         Color="{StaticResource ColorTextPrimary}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush"       Color="{StaticResource ColorTextSecondary}"/>
    <SolidColorBrush x:Key="TextTertiaryBrush"        Color="{StaticResource ColorTextTertiary}"/>
    <SolidColorBrush x:Key="KnobTrackBrush"           Color="{StaticResource ColorKnobTrack}"/>
    <SolidColorBrush x:Key="KnobActiveBrush"          Color="{StaticResource ColorKnobActive}"/>
    <SolidColorBrush x:Key="WaveformBrush"            Color="{StaticResource ColorWaveform}"/>
    <SolidColorBrush x:Key="GridLinesBrush"           Color="{StaticResource ColorGridLines}"/>
    <SolidColorBrush x:Key="BorderBrush"              Color="{StaticResource ColorBorder}"/>
    <SolidColorBrush x:Key="HoverBrush"               Color="{StaticResource ColorHover}"/>

    <!-- ═══ TYPOGRAPHY ═══ -->
    <sys:Double x:Key="FontSizeHeader">12</sys:Double>
    <sys:Double x:Key="FontSizeLabel">10</sys:Double>
    <sys:Double x:Key="FontSizeValue">11</sys:Double>
    <sys:Double x:Key="FontSizeLogo">22</sys:Double>
    <FontFamily x:Key="FontFamilyUI">Segoe UI, Calibri, sans-serif</FontFamily>
    <FontFamily x:Key="FontFamilyMono">Consolas, Cascadia Mono, monospace</FontFamily>

    <!-- Blue glow -->
    <DropShadowEffect x:Key="GlowGreen"     Color="#FF00C8FF" BlurRadius="10" ShadowDepth="0" Opacity="0.7"/>
    <DropShadowEffect x:Key="GlowGreenSoft" Color="#FF00C8FF" BlurRadius="5"  ShadowDepth="0" Opacity="0.4"/>

    <!-- ═══ TEXT STYLES ═══ -->
    <Style x:Key="HeaderTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground"  Value="{StaticResource AccentPrimaryBrush}"/>
        <Setter Property="FontSize"    Value="{StaticResource FontSizeHeader}"/>
        <Setter Property="FontWeight"  Value="SemiBold"/>
        <Setter Property="FontFamily"  Value="{StaticResource FontFamilyUI}"/>
        <Setter Property="Effect"      Value="{StaticResource GlowGreenSoft}"/>
    </Style>

    <Style x:Key="LabelTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
        <Setter Property="FontSize"   Value="{StaticResource FontSizeLabel}"/>
        <Setter Property="FontFamily" Value="{StaticResource FontFamilyUI}"/>
    </Style>

    <Style x:Key="ValueTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="FontSize"   Value="{StaticResource FontSizeValue}"/>
        <Setter Property="FontFamily" Value="{StaticResource FontFamilyUI}"/>
    </Style>

    <!-- ═══ PANEL (glass feel: slightly lighter border, subtle rounding) ═══ -->
    <Style x:Key="SynthPanelBorder" TargetType="Border">
        <Setter Property="Background">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#FF0C1B30" Offset="0"/>
                    <GradientStop Color="#FF080F1E" Offset="1"/>
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
        <Setter Property="BorderBrush"     Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius"    Value="6"/>
        <Setter Property="Padding"         Value="8"/>
        <Setter Property="Margin"          Value="3"/>
    </Style>

    <!-- ═══ BUTTON ═══ -->
    <Style x:Key="SynthButtonStyle" TargetType="Button">
        <Setter Property="Background"     Value="{StaticResource BackgroundSecondaryBrush}"/>
        <Setter Property="Foreground"     Value="{StaticResource AccentPrimaryBrush}"/>
        <Setter Property="BorderBrush"    Value="{StaticResource AccentSecondaryBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding"        Value="12,4"/>
        <Setter Property="FontFamily"     Value="{StaticResource FontFamilyUI}"/>
        <Setter Property="FontSize"       Value="11"/>
        <Setter Property="Cursor"         Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background"  Value="{StaticResource HoverBrush}"/>
                            <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource AccentPrimaryBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource AccentSecondaryBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══ COMBOBOX ═══ -->
    <Style TargetType="ComboBoxItem" x:Key="SynthComboBoxItemStyle">
        <Setter Property="Background"  Value="{StaticResource BackgroundSecondaryBrush}"/>
        <Setter Property="Foreground"  Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="FontFamily"  Value="{StaticResource FontFamilyUI}"/>
        <Setter Property="Padding"     Value="6,3"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBoxItem">
                    <Border x:Name="ItemBorder" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                        <ContentPresenter/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource HoverBrush}"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource AccentSecondaryBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <ControlTemplate x:Key="SynthComboBoxToggleButton" TargetType="ToggleButton">
        <Border x:Name="ToggleBorder" Background="{StaticResource BackgroundSecondaryBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                </Grid.ColumnDefinitions>
                <Path Grid.Column="1" Data="M 0 0 L 4 4 L 8 0 Z"
                      Fill="{StaticResource AccentPrimaryBrush}"
                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>
        </Border>
        <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="ToggleBorder" Property="BorderBrush" Value="{StaticResource AccentPrimaryBrush}"/>
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <Style x:Key="SynthComboBoxStyle" TargetType="ComboBox">
        <Setter Property="Background"         Value="{StaticResource BackgroundSecondaryBrush}"/>
        <Setter Property="Foreground"         Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="BorderBrush"        Value="{StaticResource BorderBrush}"/>
        <Setter Property="FontFamily"         Value="{StaticResource FontFamilyUI}"/>
        <Setter Property="FontSize"           Value="11"/>
        <Setter Property="ItemContainerStyle" Value="{StaticResource SynthComboBoxItemStyle}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid>
                        <ToggleButton x:Name="ToggleButton" Template="{StaticResource SynthComboBoxToggleButton}"
                                      Focusable="False"
                                      IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                      ClickMode="Press"/>
                        <ContentPresenter x:Name="ContentSite"
                                          Content="{TemplateBinding SelectionBoxItem}"
                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                          Margin="6,3,24,3" VerticalAlignment="Center" HorizontalAlignment="Left"
                                          IsHitTestVisible="False"/>
                        <Popup x:Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}"
                               AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                            <Border x:Name="DropDownBorder"
                                    Background="{StaticResource BackgroundSecondaryBrush}"
                                    BorderBrush="{StaticResource AccentSecondaryBrush}" BorderThickness="1"
                                    CornerRadius="4" SnapsToDevicePixels="True"
                                    MinWidth="{Binding ActualWidth, ElementName=ToggleButton}"
                                    MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                <ScrollViewer SnapsToDevicePixels="True">
                                    <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══ SLIDER ═══ -->
    <Style x:Key="SynthSliderStyle" TargetType="Slider">
        <Setter Property="Background" Value="{StaticResource KnobTrackBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource AccentPrimaryBrush}"/>
        <Setter Property="Height"     Value="20"/>
        <Setter Property="Margin"     Value="0,4"/>
    </Style>

    <!-- ═══ CHECKBOX ═══ -->
    <Style x:Key="SynthCheckBoxStyle" TargetType="CheckBox">
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="FontFamily" Value="{StaticResource FontFamilyUI}"/>
        <Setter Property="FontSize"   Value="11"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>

    <!-- ═══ TOOLTIP ═══ -->
    <Style TargetType="ToolTip">
        <Setter Property="Background"      Value="{StaticResource BackgroundSecondaryBrush}"/>
        <Setter Property="Foreground"      Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="BorderBrush"     Value="{StaticResource AccentPrimaryBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding"         Value="6,4"/>
        <Setter Property="FontFamily"      Value="{StaticResource FontFamilyMono}"/>
        <Setter Property="FontSize"        Value="10"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToolTip">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══ GLOBAL DEFAULTS ═══ -->
    <Style TargetType="ComboBox"  BasedOn="{StaticResource SynthComboBoxStyle}"/>
    <Style TargetType="CheckBox"  BasedOn="{StaticResource SynthCheckBoxStyle}"/>
    <Style TargetType="Button"    BasedOn="{StaticResource SynthButtonStyle}"/>
    <Style TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="FontFamily" Value="{StaticResource FontFamilyUI}"/>
    </Style>

    <!-- ═══ SYNTH CONTROLS ═══ -->
    <conv:BoolToStarConverter x:Key="BoolToStarConverter"/>

    <Style TargetType="ctl:SynthKnob">
        <Setter Property="AccentBrush"        Value="{DynamicResource KnobActiveBrush}"/>
        <Setter Property="TrackBrush"         Value="{DynamicResource KnobTrackBrush}"/>
        <Setter Property="CenterFillBrush"    Value="{DynamicResource BackgroundSecondaryBrush}"/>
        <Setter Property="CenterBorderBrush"  Value="{DynamicResource BorderBrush}"/>
        <Setter Property="LabelBrush"         Value="{DynamicResource TextSecondaryBrush}"/>
        <Setter Property="ValueBrush"         Value="{DynamicResource TextPrimaryBrush}"/>
    </Style>

    <Style TargetType="ctl:SynthSlider">
        <Setter Property="Background" Value="{DynamicResource KnobTrackBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource KnobActiveBrush}"/>
        <Setter Property="Height"     Value="20"/>
        <Setter Property="Margin"     Value="0,4"/>
    </Style>

    <!-- ═══ SCROLLBAR (thin, themed) ═══ -->
    <Style TargetType="ScrollViewer">
        <Setter Property="Background" Value="Transparent"/>
    </Style>

    <Style TargetType="ScrollBar">
        <Setter Property="Background"  Value="{StaticResource BackgroundSecondaryBrush}"/>
        <Setter Property="Foreground"  Value="{StaticResource TextTertiaryBrush}"/>
        <Setter Property="Width"       Value="8"/>
        <Setter Property="MinWidth"    Value="8"/>
    </Style>

    <Style TargetType="ctl:PianoKeyboard">
        <Setter Property="Background"          Value="{StaticResource BackgroundDeepBrush}"/>
        <Setter Property="KeyWhiteBrush"       Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="KeyWhiteActiveBrush" Value="{StaticResource AccentPrimaryBrush}"/>
        <Setter Property="KeyBlackBrush"       Value="{StaticResource BackgroundSecondaryBrush}"/>
        <Setter Property="KeyBlackActiveBrush" Value="{StaticResource AccentTertiaryBrush}"/>
        <Setter Property="KeyBorderBrush"      Value="{StaticResource BorderBrush}"/>
    </Style>

</ResourceDictionary>
