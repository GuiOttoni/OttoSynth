<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib"
                    xmlns:ctl="clr-namespace:OttoSynth.UI.Controls"
                    xmlns:conv="clr-namespace:OttoSynth.UI.Converters">

    <!-- ═══════════════ MATRIX / CYBERPUNK PALETTE ═══════════════ -->
    <!-- Deep black backgrounds with phosphor-green accents             -->
    <!-- Inspiration: The Matrix, Blade Runner, Neuromancer, CRT       -->

    <Color x:Key="ColorBackgroundPrimary">#FF030605</Color>     <!-- near-black with green tint -->
    <Color x:Key="ColorBackgroundSecondary">#FF071A0E</Color>   <!-- deep forest -->
    <Color x:Key="ColorBackgroundPanel">#FF0A1F12</Color>       <!-- panel green-black -->
    <Color x:Key="ColorBackgroundDeep">#FF010402</Color>        <!-- void -->

    <!-- Phosphor green (Matrix iconic) -->
    <Color x:Key="ColorAccentPrimary">#FF00FF41</Color>         <!-- matrix bright green -->
    <Color x:Key="ColorAccentSecondary">#FF00C233</Color>       <!-- medium green -->
    <Color x:Key="ColorAccentTertiary">#FFFF003C</Color>        <!-- cyberpunk red alarm -->
    <Color x:Key="ColorAccentAmber">#FFFFB000</Color>           <!-- terminal amber alternate -->

    <!-- Glowing greens for text -->
    <Color x:Key="ColorTextPrimary">#FFB0FFB0</Color>           <!-- pale green text -->
    <Color x:Key="ColorTextSecondary">#FF4FA659</Color>         <!-- dim green -->
    <Color x:Key="ColorTextTertiary">#FF2D6B36</Color>          <!-- very dim -->

    <Color x:Key="ColorKnobTrack">#FF0A2914</Color>             <!-- deep green track -->
    <Color x:Key="ColorKnobActive">#FF00FF41</Color>            <!-- bright phosphor -->
    <Color x:Key="ColorWaveform">#FF00FF41</Color>              <!-- glowing waveform -->
    <Color x:Key="ColorGridLines">#FF0D2914</Color>             <!-- scanline grid -->
    <Color x:Key="ColorBorder">#FF1A4D23</Color>                <!-- darker green border -->
    <Color x:Key="ColorHover">#FF143D1F</Color>                 <!-- hover green -->

    <SolidColorBrush x:Key="BackgroundPrimaryBrush" Color="{StaticResource ColorBackgroundPrimary}"/>
    <SolidColorBrush x:Key="BackgroundSecondaryBrush" Color="{StaticResource ColorBackgroundSecondary}"/>
    <SolidColorBrush x:Key="BackgroundPanelBrush" Color="{StaticResource ColorBackgroundPanel}"/>
    <SolidColorBrush x:Key="BackgroundDeepBrush" Color="{StaticResource ColorBackgroundDeep}"/>
    <SolidColorBrush x:Key="AccentPrimaryBrush" Color="{StaticResource ColorAccentPrimary}"/>
    <SolidColorBrush x:Key="AccentSecondaryBrush" Color="{StaticResource ColorAccentSecondary}"/>
    <SolidColorBrush x:Key="AccentTertiaryBrush" Color="{StaticResource ColorAccentTertiary}"/>
    <SolidColorBrush x:Key="AccentAmberBrush" Color="{StaticResource ColorAccentAmber}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource ColorTextPrimary}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource ColorTextSecondary}"/>
    <SolidColorBrush x:Key="TextTertiaryBrush" Color="{StaticResource ColorTextTertiary}"/>
    <SolidColorBrush x:Key="KnobTrackBrush" Color="{StaticResource ColorKnobTrack}"/>
    <SolidColorBrush x:Key="KnobActiveBrush" Color="{StaticResource ColorKnobActive}"/>
    <SolidColorBrush x:Key="WaveformBrush" Color="{StaticResource ColorWaveform}"/>
    <SolidColorBrush x:Key="GridLinesBrush" Color="{StaticResource ColorGridLines}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource ColorBorder}"/>
    <SolidColorBrush x:Key="HoverBrush" Color="{StaticResource ColorHover}"/>

    <!-- ═══════════════ TYPOGRAPHY (MONOSPACE) ═══════════════ -->
    <sys:Double x:Key="FontSizeHeader">13</sys:Double>
    <sys:Double x:Key="FontSizeLabel">10</sys:Double>
    <sys:Double x:Key="FontSizeValue">11</sys:Double>
    <sys:Double x:Key="FontSizeLogo">22</sys:Double>
    <!-- Monospace font for that terminal/Matrix vibe. Cascadia Mono ships with Windows 11. -->
    <FontFamily x:Key="FontFamilyUI">Cascadia Mono, Consolas, Courier New, monospace</FontFamily>
    <FontFamily x:Key="FontFamilyMono">Cascadia Mono, Consolas, Courier New, monospace</FontFamily>

    <!-- ═══════════════ EFFECTS (GLOW) ═══════════════ -->
    <DropShadowEffect x:Key="GlowGreen"
                      Color="{StaticResource ColorAccentPrimary}"
                      BlurRadius="8" ShadowDepth="0" Opacity="0.8"/>
    <DropShadowEffect x:Key="GlowGreenSoft"
                      Color="{StaticResource ColorAccentPrimary}"
                      BlurRadius="4" ShadowDepth="0" Opacity="0.4"/>

    <!-- ═══════════════ TEXT STYLES ═══════════════ -->
    <Style x:Key="HeaderTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource AccentPrimaryBrush}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeHeader}"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="FontFamily" Value="{StaticResource FontFamilyMono}"/>
        <Setter Property="Effect" Value="{StaticResource GlowGreenSoft}"/>
    </Style>

    <Style x:Key="LabelTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeLabel}"/>
        <Setter Property="FontFamily" Value="{StaticResource FontFamilyMono}"/>
    </Style>

    <Style x:Key="ValueTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeValue}"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="FontFamily" Value="{StaticResource FontFamilyMono}"/>
    </Style>

    <!-- ═══════════════ PANEL STYLE ═══════════════ -->
    <!-- Sharp corners (no rounding) + thin green border = terminal feel -->
    <Style x:Key="SynthPanelBorder" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource BackgroundPanelBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="0"/>
        <Setter Property="Padding" Value="10"/>
        <Setter Property="Margin" Value="3"/>
    </Style>

    <!-- ═══════════════ BUTTON STYLE ═══════════════ -->
    <Style x:Key="SynthButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource BackgroundSecondaryBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource AccentPrimaryBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource AccentPrimaryBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="14,5"/>
        <Setter Property="FontFamily" Value="{StaticResource FontFamilyMono}"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="0"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource AccentPrimaryBrush}"/>
                            <Setter Property="Foreground" Value="#FF000000"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource AccentSecondaryBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════════ COMBOBOX STYLE ═══════════════ -->
    <Style TargetType="ComboBoxItem" x:Key="SynthComboBoxItemStyle">
        <Setter Property="Background" Value="{StaticResource BackgroundSecondaryBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="FontFamily" Value="{StaticResource FontFamilyMono}"/>
        <Setter Property="Padding" Value="6,3"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBoxItem">
                    <Border x:Name="ItemBorder"
                            Background="{TemplateBinding Background}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource AccentPrimaryBrush}"/>
                            <Setter Property="Foreground" Value="#FF000000"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource AccentSecondaryBrush}"/>
                            <Setter Property="Foreground" Value="#FF000000"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <ControlTemplate x:Key="SynthComboBoxToggleButton" TargetType="ToggleButton">
        <Border x:Name="ToggleBorder"
                Background="{StaticResource BackgroundSecondaryBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                </Grid.ColumnDefinitions>
                <Path Grid.Column="1"
                      Data="M 0 0 L 4 4 L 8 0 Z"
                      Fill="{StaticResource AccentPrimaryBrush}"
                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>
        </Border>
        <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="ToggleBorder" Property="BorderBrush" Value="{StaticResource AccentPrimaryBrush}"/>
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <Style x:Key="SynthComboBoxStyle" TargetType="ComboBox">
        <Setter Property="Background" Value="{StaticResource BackgroundSecondaryBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="FontFamily" Value="{StaticResource FontFamilyMono}"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="ItemContainerStyle" Value="{StaticResource SynthComboBoxItemStyle}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid>
                        <ToggleButton x:Name="ToggleButton"
                                      Template="{StaticResource SynthComboBoxToggleButton}"
                                      Focusable="False"
                                      IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                      ClickMode="Press"/>
                        <ContentPresenter x:Name="ContentSite"
                                          Content="{TemplateBinding SelectionBoxItem}"
                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                          ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                          Margin="6,3,24,3"
                                          VerticalAlignment="Center"
                                          HorizontalAlignment="Left"
                                          IsHitTestVisible="False"/>
                        <Popup x:Name="Popup"
                               Placement="Bottom"
                               IsOpen="{TemplateBinding IsDropDownOpen}"
                               AllowsTransparency="True"
                               Focusable="False"
                               PopupAnimation="Slide">
                            <Border x:Name="DropDownBorder"
                                    Background="{StaticResource BackgroundSecondaryBrush}"
                                    BorderBrush="{StaticResource AccentPrimaryBrush}"
                                    BorderThickness="1"
                                    CornerRadius="0"
                                    SnapsToDevicePixels="True"
                                    MinWidth="{Binding ActualWidth, ElementName=ToggleButton}"
                                    MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                <ScrollViewer SnapsToDevicePixels="True">
                                    <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════════ CHECKBOX STYLE ═══════════════ -->
    <Style x:Key="SynthCheckBoxStyle" TargetType="CheckBox">
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="FontFamily" Value="{StaticResource FontFamilyMono}"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>

    <!-- ═══════════════ SLIDER STYLE ═══════════════ -->
    <Style x:Key="SynthSliderStyle" TargetType="Slider">
        <Setter Property="Background" Value="{StaticResource KnobTrackBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource AccentPrimaryBrush}"/>
        <Setter Property="Height" Value="20"/>
        <Setter Property="Margin" Value="0,4"/>
    </Style>

    <!-- ═══════════════ TOOLTIP STYLE ═══════════════ -->
    <Style TargetType="ToolTip">
        <Setter Property="Background"      Value="{StaticResource BackgroundSecondaryBrush}"/>
        <Setter Property="Foreground"      Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="BorderBrush"     Value="{StaticResource AccentPrimaryBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding"         Value="6,4"/>
        <Setter Property="FontFamily"      Value="{StaticResource FontFamilyMono}"/>
        <Setter Property="FontSize"        Value="10"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToolTip">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="2"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════════ GLOBAL DEFAULTS FOR UNSTYLED ELEMENTS ═══════════════ -->
    <!-- ComboBox without explicit style still inherits these -->
    <Style TargetType="ComboBox" BasedOn="{StaticResource SynthComboBoxStyle}"/>
    <Style TargetType="CheckBox" BasedOn="{StaticResource SynthCheckBoxStyle}"/>
    <Style TargetType="Button" BasedOn="{StaticResource SynthButtonStyle}"/>
    <Style TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="FontFamily" Value="{StaticResource FontFamilyMono}"/>
    </Style>

    <!-- ═══════════════ SYNTH CONTROLS ═══════════════ -->
    <conv:BoolToStarConverter x:Key="BoolToStarConverter"/>

    <Style TargetType="ctl:SynthKnob">
        <Setter Property="AccentBrush"        Value="{DynamicResource KnobActiveBrush}"/>
        <Setter Property="TrackBrush"         Value="{DynamicResource KnobTrackBrush}"/>
        <Setter Property="CenterFillBrush"    Value="{DynamicResource BackgroundSecondaryBrush}"/>
        <Setter Property="CenterBorderBrush"  Value="{DynamicResource BorderBrush}"/>
        <Setter Property="LabelBrush"         Value="{DynamicResource TextSecondaryBrush}"/>
        <Setter Property="ValueBrush"         Value="{DynamicResource TextPrimaryBrush}"/>
    </Style>

    <Style TargetType="ctl:SynthSlider">
        <Setter Property="Background" Value="{DynamicResource KnobTrackBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource KnobActiveBrush}"/>
        <Setter Property="Height"     Value="20"/>
        <Setter Property="Margin"     Value="0,4"/>
    </Style>

    <!-- ═══════════════ SCROLLBAR (thin, themed) ═══════════════ -->
    <Style TargetType="ScrollViewer">
        <Setter Property="Background" Value="Transparent"/>
    </Style>

    <Style TargetType="ScrollBar">
        <Setter Property="Background"  Value="{StaticResource BackgroundSecondaryBrush}"/>
        <Setter Property="Foreground"  Value="{StaticResource TextTertiaryBrush}"/>
        <Setter Property="Width"       Value="8"/>
        <Setter Property="MinWidth"    Value="8"/>
    </Style>

    <Style TargetType="ctl:PianoKeyboard">
        <Setter Property="Background"          Value="{StaticResource BackgroundDeepBrush}"/>
        <Setter Property="KeyWhiteBrush"       Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="KeyWhiteActiveBrush" Value="{StaticResource AccentPrimaryBrush}"/>
        <Setter Property="KeyBlackBrush"       Value="{StaticResource BackgroundSecondaryBrush}"/>
        <Setter Property="KeyBlackActiveBrush" Value="{StaticResource AccentAmberBrush}"/>
        <Setter Property="KeyBorderBrush"      Value="{StaticResource BorderBrush}"/>
    </Style>

</ResourceDictionary>
