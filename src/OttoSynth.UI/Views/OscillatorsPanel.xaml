<UserControl x:Class="OttoSynth.UI.Views.OscillatorsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctl="clr-namespace:OttoSynth.UI.Controls">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
    <StackPanel Orientation="Vertical">

        <!-- ── Oscillators ── -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- OSC 1 -->
            <Grid Grid.Column="0" Margin="0,0,3,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <CheckBox Grid.Column="0" Content="OSC 1"
                              IsChecked="{Binding Osc1.IsEnabled, Mode=TwoWay}"
                              Foreground="{DynamicResource AccentPrimaryBrush}" FontFamily="Segoe UI" FontWeight="SemiBold"/>
                    <Button Grid.Column="1" Content="LOAD" Padding="4,1" FontSize="9"
                            Click="OnLoadWavetable1Click" ToolTip="Load wavetable from .wav file"/>
                </Grid>
                <ComboBox Grid.Row="1" Margin="0,4,0,2" Style="{DynamicResource SynthComboBoxStyle}"
                          ItemsSource="{Binding WavetableNames}"
                          SelectedItem="{Binding Osc1.SelectedWavetable, Mode=TwoWay}"/>
                <ComboBox Grid.Row="2" Margin="0,2,0,4" Style="{DynamicResource SynthComboBoxStyle}"
                          ToolTip="Warp type"
                          ItemsSource="{Binding WarpTypes}"
                          SelectedItem="{Binding Osc1.SelectedWarp, Mode=TwoWay}"/>
                <UniformGrid Grid.Row="3" Columns="3">
                    <ctl:SynthKnob Label="LEVEL"  Minimum="0"    Maximum="1"    Value="{Binding Osc1.Level, Mode=TwoWay}"      DefaultValue="0.8"  ValueFormat="P0"/>
                    <ctl:SynthKnob Label="POS"    Minimum="0"    Maximum="1"    Value="{Binding Osc1.Position, Mode=TwoWay}"   DefaultValue="0"    ValueFormat="P0" ToolTip="Wavetable position"/>
                    <ctl:SynthKnob Label="WARP"   Minimum="0"    Maximum="1"    Value="{Binding Osc1.WarpAmount, Mode=TwoWay}" DefaultValue="0"    ValueFormat="P0"/>
                    <ctl:SynthKnob Label="COARSE" Minimum="-24"  Maximum="24"   Value="{Binding Osc1.CoarseTune, Mode=TwoWay}" DefaultValue="0"    IsBipolar="True" ValueFormat="F0" Unit=" st"/>
                    <ctl:SynthKnob Label="FINE"   Minimum="-100" Maximum="100"  Value="{Binding Osc1.FineTune, Mode=TwoWay}"   DefaultValue="0"    IsBipolar="True" ValueFormat="F0" Unit=" ¢"/>
                    <ctl:SynthKnob Label="PAN"    Minimum="-1"   Maximum="1"    Value="{Binding Osc1.Pan, Mode=TwoWay}"        DefaultValue="0"    IsBipolar="True" ValueFormat="F2"/>
                </UniformGrid>
                <StackPanel Grid.Row="4" Orientation="Vertical" Margin="0,4,0,0">
                    <TextBlock Text="UNISON" Style="{DynamicResource LabelTextStyle}" Margin="2,0,0,2"/>
                    <UniformGrid Columns="3">
                        <ctl:SynthKnob Label="VOICES" Minimum="1" Maximum="16" Value="{Binding Osc1.UnisonVoices, Mode=TwoWay}" DefaultValue="1"  ValueFormat="F0"/>
                        <ctl:SynthKnob Label="DETUNE" Minimum="0" Maximum="100" Value="{Binding Osc1.UnisonDetune, Mode=TwoWay}" DefaultValue="20" ValueFormat="F0" Unit=" ¢"/>
                        <ctl:SynthKnob Label="SPREAD" Minimum="0" Maximum="1"   Value="{Binding Osc1.UnisonSpread, Mode=TwoWay}" DefaultValue="0.8" ValueFormat="P0"/>
                    </UniformGrid>
                </StackPanel>
            </Grid>

            <!-- OSC 2 -->
            <Grid Grid.Column="1" Margin="3,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <CheckBox Grid.Column="0" Content="OSC 2"
                              IsChecked="{Binding Osc2.IsEnabled, Mode=TwoWay}"
                              Foreground="{DynamicResource AccentPrimaryBrush}" FontFamily="Segoe UI" FontWeight="SemiBold"/>
                    <Button Grid.Column="1" Content="LOAD" Padding="4,1" FontSize="9"
                            Click="OnLoadWavetable2Click" ToolTip="Load wavetable from .wav file"/>
                </Grid>
                <ComboBox Grid.Row="1" Margin="0,4,0,2" Style="{DynamicResource SynthComboBoxStyle}"
                          ItemsSource="{Binding WavetableNames}"
                          SelectedItem="{Binding Osc2.SelectedWavetable, Mode=TwoWay}"/>
                <ComboBox Grid.Row="2" Margin="0,2,0,4" Style="{DynamicResource SynthComboBoxStyle}"
                          ItemsSource="{Binding WarpTypes}"
                          SelectedItem="{Binding Osc2.SelectedWarp, Mode=TwoWay}"/>
                <UniformGrid Grid.Row="3" Columns="3">
                    <ctl:SynthKnob Label="LEVEL"  Minimum="0"    Maximum="1"    Value="{Binding Osc2.Level, Mode=TwoWay}"      DefaultValue="0.6"  ValueFormat="P0"/>
                    <ctl:SynthKnob Label="POS"    Minimum="0"    Maximum="1"    Value="{Binding Osc2.Position, Mode=TwoWay}"   DefaultValue="0"    ValueFormat="P0"/>
                    <ctl:SynthKnob Label="WARP"   Minimum="0"    Maximum="1"    Value="{Binding Osc2.WarpAmount, Mode=TwoWay}" DefaultValue="0"    ValueFormat="P0"/>
                    <ctl:SynthKnob Label="COARSE" Minimum="-24"  Maximum="24"   Value="{Binding Osc2.CoarseTune, Mode=TwoWay}" DefaultValue="0"    IsBipolar="True" ValueFormat="F0" Unit=" st"/>
                    <ctl:SynthKnob Label="FINE"   Minimum="-100" Maximum="100"  Value="{Binding Osc2.FineTune, Mode=TwoWay}"   DefaultValue="0"    IsBipolar="True" ValueFormat="F0" Unit=" ¢"/>
                    <ctl:SynthKnob Label="PAN"    Minimum="-1"   Maximum="1"    Value="{Binding Osc2.Pan, Mode=TwoWay}"        DefaultValue="0"    IsBipolar="True" ValueFormat="F2"/>
                </UniformGrid>
                <StackPanel Grid.Row="4" Orientation="Vertical" Margin="0,4,0,0">
                    <TextBlock Text="UNISON" Style="{DynamicResource LabelTextStyle}" Margin="2,0,0,2"/>
                    <UniformGrid Columns="3">
                        <ctl:SynthKnob Label="VOICES" Minimum="1" Maximum="16" Value="{Binding Osc2.UnisonVoices, Mode=TwoWay}" DefaultValue="1"  ValueFormat="F0"/>
                        <ctl:SynthKnob Label="DETUNE" Minimum="0" Maximum="100" Value="{Binding Osc2.UnisonDetune, Mode=TwoWay}" DefaultValue="20" ValueFormat="F0" Unit=" ¢"/>
                        <ctl:SynthKnob Label="SPREAD" Minimum="0" Maximum="1"   Value="{Binding Osc2.UnisonSpread, Mode=TwoWay}" DefaultValue="0.8" ValueFormat="P0"/>
                    </UniformGrid>
                </StackPanel>
            </Grid>

            <!-- OSC 3 -->
            <Grid Grid.Column="2" Margin="3,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <CheckBox Grid.Column="0" Content="OSC 3"
                              IsChecked="{Binding Osc3.IsEnabled, Mode=TwoWay}"
                              Foreground="{DynamicResource AccentPrimaryBrush}" FontFamily="Segoe UI" FontWeight="SemiBold"/>
                    <Button Grid.Column="1" Content="LOAD" Padding="4,1" FontSize="9"
                            Click="OnLoadWavetable3Click" ToolTip="Load wavetable from .wav file"/>
                </Grid>
                <ComboBox Grid.Row="1" Margin="0,4,0,2" Style="{DynamicResource SynthComboBoxStyle}"
                          ItemsSource="{Binding WavetableNames}"
                          SelectedItem="{Binding Osc3.SelectedWavetable, Mode=TwoWay}"/>
                <ComboBox Grid.Row="2" Margin="0,2,0,4" Style="{DynamicResource SynthComboBoxStyle}"
                          ItemsSource="{Binding WarpTypes}"
                          SelectedItem="{Binding Osc3.SelectedWarp, Mode=TwoWay}"/>
                <UniformGrid Grid.Row="3" Columns="3">
                    <ctl:SynthKnob Label="LEVEL"  Minimum="0"    Maximum="1"    Value="{Binding Osc3.Level, Mode=TwoWay}"      DefaultValue="0.5"  ValueFormat="P0"/>
                    <ctl:SynthKnob Label="POS"    Minimum="0"    Maximum="1"    Value="{Binding Osc3.Position, Mode=TwoWay}"   DefaultValue="0"    ValueFormat="P0"/>
                    <ctl:SynthKnob Label="WARP"   Minimum="0"    Maximum="1"    Value="{Binding Osc3.WarpAmount, Mode=TwoWay}" DefaultValue="0"    ValueFormat="P0"/>
                    <ctl:SynthKnob Label="COARSE" Minimum="-24"  Maximum="24"   Value="{Binding Osc3.CoarseTune, Mode=TwoWay}" DefaultValue="0"    IsBipolar="True" ValueFormat="F0" Unit=" st"/>
                    <ctl:SynthKnob Label="FINE"   Minimum="-100" Maximum="100"  Value="{Binding Osc3.FineTune, Mode=TwoWay}"   DefaultValue="0"    IsBipolar="True" ValueFormat="F0" Unit=" ¢"/>
                    <ctl:SynthKnob Label="PAN"    Minimum="-1"   Maximum="1"    Value="{Binding Osc3.Pan, Mode=TwoWay}"        DefaultValue="0"    IsBipolar="True" ValueFormat="F2"/>
                </UniformGrid>
                <StackPanel Grid.Row="4" Orientation="Vertical" Margin="0,4,0,0">
                    <TextBlock Text="UNISON" Style="{DynamicResource LabelTextStyle}" Margin="2,0,0,2"/>
                    <UniformGrid Columns="3">
                        <ctl:SynthKnob Label="VOICES" Minimum="1" Maximum="16" Value="{Binding Osc3.UnisonVoices, Mode=TwoWay}" DefaultValue="1"  ValueFormat="F0"/>
                        <ctl:SynthKnob Label="DETUNE" Minimum="0" Maximum="100" Value="{Binding Osc3.UnisonDetune, Mode=TwoWay}" DefaultValue="20" ValueFormat="F0" Unit=" ¢"/>
                        <ctl:SynthKnob Label="SPREAD" Minimum="0" Maximum="1"   Value="{Binding Osc3.UnisonSpread, Mode=TwoWay}" DefaultValue="0.8" ValueFormat="P0"/>
                    </UniformGrid>
                </StackPanel>
            </Grid>
        </Grid>

        <!-- ── Routing Matrix ── -->
        <Border Margin="0,8,0,0" Padding="6,4"
                Background="{DynamicResource BackgroundSecondaryBrush}"
                CornerRadius="4">
            <StackPanel Orientation="Vertical">
                <TextBlock Text="ROUTING MATRIX" Style="{DynamicResource LabelTextStyle}"
                           FontWeight="SemiBold" Foreground="{DynamicResource AccentSecondaryBrush}"
                           Margin="0,0,0,6"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="52"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="1" Text="→ OSC 1" HorizontalAlignment="Center"
                               Style="{DynamicResource LabelTextStyle}" Foreground="{DynamicResource AccentPrimaryBrush}"/>
                    <TextBlock Grid.Row="0" Grid.Column="2" Text="→ OSC 2" HorizontalAlignment="Center"
                               Style="{DynamicResource LabelTextStyle}" Foreground="{DynamicResource AccentPrimaryBrush}"/>
                    <TextBlock Grid.Row="0" Grid.Column="3" Text="→ OSC 3" HorizontalAlignment="Center"
                               Style="{DynamicResource LabelTextStyle}" Foreground="{DynamicResource AccentPrimaryBrush}"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="OSC 1" VerticalAlignment="Center"
                               Style="{DynamicResource LabelTextStyle}" Foreground="{DynamicResource AccentPrimaryBrush}"/>
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="OSC 2" VerticalAlignment="Center"
                               Style="{DynamicResource LabelTextStyle}" Foreground="{DynamicResource AccentPrimaryBrush}"/>
                    <TextBlock Grid.Row="3" Grid.Column="0" Text="OSC 3" VerticalAlignment="Center"
                               Style="{DynamicResource LabelTextStyle}" Foreground="{DynamicResource AccentPrimaryBrush}"/>

                    <ItemsControl Grid.Row="1" Grid.RowSpan="3"
                                  Grid.Column="1" Grid.ColumnSpan="3"
                                  ItemsSource="{Binding RoutingMatrix.AllCells}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Rows="3" Columns="3"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="2" Padding="3,2"
                                        Background="{DynamicResource BackgroundPrimaryBrush}"
                                        CornerRadius="3"
                                        Opacity="{Binding CellOpacity}">
                                    <Grid>
                                        <TextBlock Text="—"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   Foreground="{DynamicResource TextTertiaryBrush}"
                                                   Visibility="{Binding DiagonalVisibility}"/>
                                        <StackPanel Visibility="{Binding ActiveVisibility}">
                                            <ComboBox Style="{DynamicResource SynthComboBoxStyle}"
                                                      ItemsSource="{Binding RoutingModes}"
                                                      SelectedItem="{Binding SelectedMode, Mode=TwoWay}"
                                                      ToolTip="{Binding Label}"/>
                                            <ctl:SynthKnob Label="DEPTH" Minimum="0" Maximum="1"
                                                           Value="{Binding FmDepth, Mode=TwoWay}"
                                                           DefaultValue="0.5" ValueFormat="P0" Height="40"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </StackPanel>
        </Border>

    </StackPanel>
    </ScrollViewer>
</UserControl>
