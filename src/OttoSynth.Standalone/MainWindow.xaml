<Window x:Class="OttoSynth.Standalone.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ctl="clr-namespace:OttoSynth.UI.Controls;assembly=OttoSynth.UI"
        Title="OttoSynth // MATRIX EDITION"
        Width="1280" Height="950"
        MinWidth="1060" MinHeight="820"
        Background="#FF030605"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded"
        Closing="Window_Closing">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/OttoSynth.UI;component/Themes/DarkTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="54"/>   <!-- Header -->
            <RowDefinition Height="*"/>    <!-- Main Content -->
            <RowDefinition Height="60"/>   <!-- Effects rack -->
            <RowDefinition Height="50"/>   <!-- Debug log -->
            <RowDefinition Height="120"/>  <!-- Keyboard -->
            <RowDefinition Height="28"/>   <!-- Status Bar -->
        </Grid.RowDefinitions>

        <!-- ═══ HEADER ═══════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="#FF010402" BorderBrush="#FF1A4D23" BorderThickness="0,0,0,1">
            <Grid Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="&gt; OTTO" FontSize="22" FontWeight="Bold"
                               Foreground="{StaticResource AccentPrimaryBrush}" FontFamily="Cascadia Mono">
                        <TextBlock.Effect>
                            <DropShadowEffect Color="#FF00FF41" BlurRadius="10" ShadowDepth="0" Opacity="0.8"/>
                        </TextBlock.Effect>
                    </TextBlock>
                    <TextBlock Text="SYNTH_" FontSize="22" FontWeight="Bold"
                               Foreground="{StaticResource AccentAmberBrush}" FontFamily="Cascadia Mono" Margin="2,0,0,0">
                        <TextBlock.Effect>
                            <DropShadowEffect Color="#FFFFB000" BlurRadius="8" ShadowDepth="0" Opacity="0.6"/>
                        </TextBlock.Effect>
                    </TextBlock>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="Preset:" Style="{StaticResource LabelTextStyle}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <ComboBox x:Name="PresetSelector" Width="180" Style="{StaticResource SynthComboBoxStyle}"
                              SelectionChanged="PresetSelector_SelectionChanged"/>
                    <Button x:Name="LoadPresetBtn"   Content="Load"    Style="{StaticResource SynthButtonStyle}" Margin="4,0,0,0" Click="LoadPresetBtn_Click"/>
                    <Button x:Name="SavePresetBtn"   Content="Save"    Style="{StaticResource SynthButtonStyle}" Margin="4,0,0,0" Click="SavePresetBtn_Click"   ToolTip="Save current state as user preset (.otto)"/>
                    <Button x:Name="ImportPresetBtn" Content="Import…" Style="{StaticResource SynthButtonStyle}" Margin="4,0,0,0" Click="ImportPresetBtn_Click" ToolTip="Import a .otto preset file"/>
                    <Button x:Name="ExportPresetBtn" Content="Export…" Style="{StaticResource SynthButtonStyle}" Margin="4,0,0,0" Click="ExportPresetBtn_Click" ToolTip="Export current state as .otto file"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="MIDI:" Style="{StaticResource LabelTextStyle}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ComboBox x:Name="MidiDeviceSelector" Width="200" Style="{StaticResource SynthComboBoxStyle}"
                              SelectionChanged="MidiDeviceSelector_SelectionChanged"/>
                    <Button x:Name="RefreshMidiBtn" Content="[ ↻ ]" Style="{StaticResource SynthButtonStyle}"
                            Margin="6,0,0,0" ToolTip="Re-scan MIDI devices" Click="RefreshMidiBtn_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ MAIN CONTENT ═════════════════════════════════════ -->
        <Grid Grid.Row="1" Margin="6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="2.2*"/>  <!-- OSC + Analyzer — most knobs here -->
                <RowDefinition Height="*"/>      <!-- Filter + Envelope -->
                <RowDefinition Height="*"/>      <!-- LFOs + ModMatrix -->
            </Grid.RowDefinitions>

            <!-- ── OSCILLATORS ─────────────────────────────────── -->
            <Border Grid.Column="0" Grid.Row="0" Style="{StaticResource SynthPanelBorder}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="// OSCILLATORS" Style="{StaticResource HeaderTextStyle}" Margin="0,0,0,6"/>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- OSC 1 -->
                        <Grid Grid.Column="0" Margin="0,0,4,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <CheckBox Grid.Row="0" x:Name="Osc1Enabled" Content="OSC 1"
                                      Foreground="{StaticResource AccentPrimaryBrush}" FontFamily="Segoe UI" FontWeight="SemiBold" IsChecked="True"
                                      Checked="OscEnabled_Changed" Unchecked="OscEnabled_Changed"/>
                            <ComboBox Grid.Row="1" x:Name="Osc1Wavetable" Margin="0,4,0,2" Style="{StaticResource SynthComboBoxStyle}"
                                      SelectionChanged="Osc1Wavetable_SelectionChanged"/>
                            <ComboBox Grid.Row="2" x:Name="Osc1WarpType" Margin="0,2,0,4" Style="{StaticResource SynthComboBoxStyle}"
                                      ToolTip="Warp / Effect type (Serum/Vital inspired)"
                                      SelectionChanged="Osc1WarpType_SelectionChanged"/>
                            <UniformGrid Grid.Row="3" Columns="3">
                                <ctl:SynthKnob x:Name="Osc1LevelKnob"    Label="LEVEL"    Minimum="0"   Maximum="1"   Value="0.8" DefaultValue="0.8" ValueFormat="P0"                   ValueChanged="Osc1Knob_ValueChanged"/>
                                <ctl:SynthKnob x:Name="Osc1PositionKnob" Label="POS"      Minimum="0"   Maximum="1"   Value="0"   DefaultValue="0"   ValueFormat="P0" ToolTip="Wavetable position (morph between frames)" ValueChanged="Osc1Knob_ValueChanged"/>
                                <ctl:SynthKnob x:Name="Osc1WarpAmt"      Label="WARP"     Minimum="0"   Maximum="1"   Value="0"   DefaultValue="0"   ValueFormat="P0" ToolTip="Warp amount" ValueChanged="Osc1Knob_ValueChanged"/>
                                <ctl:SynthKnob x:Name="Osc1CoarseKnob"   Label="COARSE"   Minimum="-24" Maximum="24"  Value="0"   DefaultValue="0"   IsBipolar="True" ValueFormat="F0" Unit=" st" ValueChanged="Osc1Knob_ValueChanged"/>
                                <ctl:SynthKnob x:Name="Osc1FineKnob"     Label="FINE"     Minimum="-100" Maximum="100" Value="0"  DefaultValue="0"   IsBipolar="True" ValueFormat="F0" Unit=" ¢" ValueChanged="Osc1Knob_ValueChanged"/>
                                <ctl:SynthKnob x:Name="Osc1PanKnob"      Label="PAN"      Minimum="-1"  Maximum="1"   Value="0"   DefaultValue="0"   IsBipolar="True" ValueFormat="F2"          ValueChanged="Osc1Knob_ValueChanged"/>
                            </UniformGrid>
                        </Grid>

                        <!-- OSC 2 -->
                        <Grid Grid.Column="1" Margin="2,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <CheckBox Grid.Row="0" x:Name="Osc2Enabled" Content="OSC 2"
                                      Foreground="{StaticResource AccentPrimaryBrush}" FontFamily="Segoe UI" FontWeight="SemiBold"
                                      Checked="OscEnabled_Changed" Unchecked="OscEnabled_Changed"/>
                            <ComboBox Grid.Row="1" x:Name="Osc2Wavetable" Margin="0,4,0,2" Style="{StaticResource SynthComboBoxStyle}"
                                      SelectionChanged="Osc2Wavetable_SelectionChanged"/>
                            <ComboBox Grid.Row="2" x:Name="Osc2WarpType" Margin="0,2,0,4" Style="{StaticResource SynthComboBoxStyle}"
                                      SelectionChanged="Osc2WarpType_SelectionChanged"/>
                            <UniformGrid Grid.Row="3" Columns="3">
                                <ctl:SynthKnob x:Name="Osc2LevelKnob"    Label="LEVEL"    Minimum="0"   Maximum="1"    Value="0.6" DefaultValue="0.6" ValueFormat="P0"                   ValueChanged="Osc2Knob_ValueChanged"/>
                                <ctl:SynthKnob x:Name="Osc2PositionKnob" Label="POS"      Minimum="0"   Maximum="1"    Value="0"   DefaultValue="0"   ValueFormat="P0"                   ValueChanged="Osc2Knob_ValueChanged"/>
                                <ctl:SynthKnob x:Name="Osc2WarpAmt"      Label="WARP"     Minimum="0"   Maximum="1"    Value="0"   DefaultValue="0"   ValueFormat="P0"                   ValueChanged="Osc2Knob_ValueChanged"/>
                                <ctl:SynthKnob x:Name="Osc2CoarseKnob"   Label="COARSE"   Minimum="-24" Maximum="24"   Value="0"   DefaultValue="0"   IsBipolar="True" ValueFormat="F0" Unit=" st" ValueChanged="Osc2Knob_ValueChanged"/>
                                <ctl:SynthKnob x:Name="Osc2FineKnob"     Label="FINE"     Minimum="-100" Maximum="100" Value="0"   DefaultValue="0"   IsBipolar="True" ValueFormat="F0" Unit=" ¢" ValueChanged="Osc2Knob_ValueChanged"/>
                                <ctl:SynthKnob x:Name="Osc2PanKnob"      Label="PAN"      Minimum="-1"  Maximum="1"    Value="0"   DefaultValue="0"   IsBipolar="True" ValueFormat="F2"          ValueChanged="Osc2Knob_ValueChanged"/>
                            </UniformGrid>
                        </Grid>

                        <!-- OSC 3 -->
                        <Grid Grid.Column="2" Margin="4,0,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <CheckBox Grid.Row="0" x:Name="Osc3Enabled" Content="OSC 3"
                                      Foreground="{StaticResource AccentPrimaryBrush}" FontFamily="Segoe UI" FontWeight="SemiBold"
                                      Checked="OscEnabled_Changed" Unchecked="OscEnabled_Changed"/>
                            <ComboBox Grid.Row="1" x:Name="Osc3Wavetable" Margin="0,4,0,2" Style="{StaticResource SynthComboBoxStyle}"
                                      SelectionChanged="Osc3Wavetable_SelectionChanged"/>
                            <ComboBox Grid.Row="2" x:Name="Osc3WarpType" Margin="0,2,0,4" Style="{StaticResource SynthComboBoxStyle}"
                                      SelectionChanged="Osc3WarpType_SelectionChanged"/>
                            <UniformGrid Grid.Row="3" Columns="3">
                                <ctl:SynthKnob x:Name="Osc3LevelKnob"    Label="LEVEL"    Minimum="0"   Maximum="1"    Value="0.5" DefaultValue="0.5" ValueFormat="P0"                   ValueChanged="Osc3Knob_ValueChanged"/>
                                <ctl:SynthKnob x:Name="Osc3PositionKnob" Label="POS"      Minimum="0"   Maximum="1"    Value="0"   DefaultValue="0"   ValueFormat="P0"                   ValueChanged="Osc3Knob_ValueChanged"/>
                                <ctl:SynthKnob x:Name="Osc3WarpAmt"      Label="WARP"     Minimum="0"   Maximum="1"    Value="0"   DefaultValue="0"   ValueFormat="P0"                   ValueChanged="Osc3Knob_ValueChanged"/>
                                <ctl:SynthKnob x:Name="Osc3CoarseKnob"   Label="COARSE"   Minimum="-24" Maximum="24"   Value="0"   DefaultValue="0"   IsBipolar="True" ValueFormat="F0" Unit=" st" ValueChanged="Osc3Knob_ValueChanged"/>
                                <ctl:SynthKnob x:Name="Osc3FineKnob"     Label="FINE"     Minimum="-100" Maximum="100" Value="0"   DefaultValue="0"   IsBipolar="True" ValueFormat="F0" Unit=" ¢" ValueChanged="Osc3Knob_ValueChanged"/>
                                <ctl:SynthKnob x:Name="Osc3PanKnob"      Label="PAN"      Minimum="-1"  Maximum="1"    Value="0"   DefaultValue="0"   IsBipolar="True" ValueFormat="F2"          ValueChanged="Osc3Knob_ValueChanged"/>
                            </UniformGrid>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>

            <!-- ── WAVEFORM / SPECTRUM ─────────────────────────── -->
            <Border Grid.Column="1" Grid.Row="0" Style="{StaticResource SynthPanelBorder}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="// ANALYZER" Style="{StaticResource HeaderTextStyle}" Margin="0,0,0,6"/>
                    <ctl:WaveformDisplay  Grid.Row="1" x:Name="WaveformView"/>
                    <ctl:SpectrumAnalyzer Grid.Row="2" x:Name="SpectrumView" Margin="0,4,0,0"/>
                </Grid>
            </Border>

            <!-- ── FILTER ──────────────────────────────────────── -->
            <Border Grid.Column="0" Grid.Row="1" Style="{StaticResource SynthPanelBorder}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="// FILTER" Style="{StaticResource HeaderTextStyle}" Margin="0,0,0,6"/>
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,0">
                            <ComboBox x:Name="FilterMode" Width="120" Style="{StaticResource SynthComboBoxStyle}"
                                      SelectionChanged="FilterMode_SelectionChanged" Margin="0,4"/>
                            <CheckBox x:Name="Filter24dB" Content="24 dB/oct" Foreground="#FFFFFF" FontFamily="Segoe UI" Margin="0,4"
                                      Checked="Filter24dB_Changed" Unchecked="Filter24dB_Changed"/>
                        </StackPanel>
                        <UniformGrid Grid.Column="1" Columns="4">
                            <ctl:SynthKnob x:Name="CutoffKnob"       Label="CUTOFF"  Minimum="20"  Maximum="20000" Value="20000" DefaultValue="20000" ValueFormat="F0" Unit=" Hz"        ValueChanged="FilterKnob_ValueChanged"/>
                            <ctl:SynthKnob x:Name="ResonanceKnob"    Label="RES"     Minimum="0"   Maximum="1"     Value="0"     DefaultValue="0"      ValueFormat="P0"                  ValueChanged="FilterKnob_ValueChanged"/>
                            <ctl:SynthKnob x:Name="DriveKnob"        Label="DRIVE"   Minimum="0"   Maximum="1"     Value="0"     DefaultValue="0"      ValueFormat="P0"                  ValueChanged="FilterKnob_ValueChanged"/>
                            <ctl:SynthKnob x:Name="FilterEnvAmtKnob" Label="ENV AMT" Minimum="-1"  Maximum="1"     Value="0"     DefaultValue="0"      IsBipolar="True" ValueFormat="F2" ValueChanged="FilterEnvAmt_Changed"/>
                        </UniformGrid>
                        <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="8,0,0,0">
                            <ctl:SynthKnob x:Name="GlideTimeKnob" Label="GLIDE" Minimum="0" Maximum="2" Value="0" DefaultValue="0" ValueFormat="F2" Unit="s"
                                           ToolTip="Portamento glide time (0 = off)" ValueChanged="GlideKnob_ValueChanged"/>
                            <ComboBox x:Name="GlideModeCombo" Width="80" Style="{StaticResource SynthComboBoxStyle}"
                                      ToolTip="Glide mode: Off, Always, Legato" Margin="0,4,0,0"
                                      SelectionChanged="GlideModeCombo_SelectionChanged"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <!-- ── AMP ENVELOPE ────────────────────────────────── -->
            <Border Grid.Column="1" Grid.Row="1" Style="{StaticResource SynthPanelBorder}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="// AMP ENVELOPE" Style="{StaticResource HeaderTextStyle}" Margin="0,0,0,6"/>
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <UniformGrid Grid.Column="0" Columns="2">
                            <ctl:SynthKnob x:Name="AttackKnob"  Label="ATTACK"  Minimum="0.001" Maximum="10" Value="0.01" DefaultValue="0.01" ValueFormat="F3" Unit="s" ValueChanged="EnvelopeKnob_ValueChanged"/>
                            <ctl:SynthKnob x:Name="DecayKnob"   Label="DECAY"   Minimum="0.001" Maximum="10" Value="0.3"  DefaultValue="0.3"  ValueFormat="F2" Unit="s" ValueChanged="EnvelopeKnob_ValueChanged"/>
                            <ctl:SynthKnob x:Name="SustainKnob" Label="SUSTAIN" Minimum="0"     Maximum="1"  Value="0.7"  DefaultValue="0.7"  ValueFormat="P0"          ValueChanged="EnvelopeKnob_ValueChanged"/>
                            <ctl:SynthKnob x:Name="ReleaseKnob" Label="RELEASE" Minimum="0.001" Maximum="10" Value="0.5"  DefaultValue="0.5"  ValueFormat="F2" Unit="s" ValueChanged="EnvelopeKnob_ValueChanged"/>
                        </UniformGrid>
                        <ctl:EnvelopeEditor Grid.Column="1" x:Name="EnvelopeView"
                                            Attack="{Binding Value, ElementName=AttackKnob}"
                                            Decay="{Binding Value, ElementName=DecayKnob}"
                                            Sustain="{Binding Value, ElementName=SustainKnob}"
                                            Release="{Binding Value, ElementName=ReleaseKnob}"/>
                    </Grid>
                </Grid>
            </Border>

            <!-- ── LFOS ────────────────────────────────────────── -->
            <Border Grid.Column="0" Grid.Row="2" Style="{StaticResource SynthPanelBorder}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="// LFOS" Style="{StaticResource HeaderTextStyle}" Margin="0,0,0,6"/>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- LFO 1 -->
                        <Grid Grid.Column="0" Margin="0,0,4,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="LFO 1" Style="{StaticResource HeaderTextStyle}" FontSize="11" Margin="2,0,0,2"/>
                            <ComboBox  Grid.Row="1" x:Name="Lfo1Shape" Style="{StaticResource SynthComboBoxStyle}" Margin="2,0,2,2"
                                       SelectionChanged="Lfo1Shape_SelectionChanged"/>
                            <ctl:LfoDisplay Grid.Row="2" x:Name="Lfo1View" Height="32" Margin="2,2"/>
                            <UniformGrid Grid.Row="3" Columns="2">
                                <ctl:SynthKnob x:Name="Lfo1Rate"  Label="RATE"  Minimum="0.01" Maximum="30" Value="1" DefaultValue="1" ValueFormat="F2" Unit=" Hz" ValueChanged="Lfo1Knob_ValueChanged"/>
                                <ctl:SynthKnob x:Name="Lfo1Depth" Label="DEPTH" Minimum="0"    Maximum="1"  Value="1" DefaultValue="1" ValueFormat="P0"            ValueChanged="Lfo1Knob_ValueChanged"/>
                            </UniformGrid>
                        </Grid>

                        <!-- LFO 2 -->
                        <Grid Grid.Column="1" Margin="2,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="LFO 2" Style="{StaticResource HeaderTextStyle}" FontSize="11" Margin="2,0,0,2"/>
                            <ComboBox  Grid.Row="1" x:Name="Lfo2Shape" Style="{StaticResource SynthComboBoxStyle}" Margin="2,0,2,2"
                                       SelectionChanged="Lfo2Shape_SelectionChanged"/>
                            <ctl:LfoDisplay Grid.Row="2" x:Name="Lfo2View" Height="32" Margin="2,2"/>
                            <UniformGrid Grid.Row="3" Columns="2">
                                <ctl:SynthKnob x:Name="Lfo2Rate"  Label="RATE"  Minimum="0.01" Maximum="30" Value="1" DefaultValue="1" ValueFormat="F2" Unit=" Hz" ValueChanged="Lfo2Knob_ValueChanged"/>
                                <ctl:SynthKnob x:Name="Lfo2Depth" Label="DEPTH" Minimum="0"    Maximum="1"  Value="1" DefaultValue="1" ValueFormat="P0"            ValueChanged="Lfo2Knob_ValueChanged"/>
                            </UniformGrid>
                        </Grid>

                        <!-- LFO 3 -->
                        <Grid Grid.Column="2" Margin="4,0,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="LFO 3" Style="{StaticResource HeaderTextStyle}" FontSize="11" Margin="2,0,0,2"/>
                            <ComboBox  Grid.Row="1" x:Name="Lfo3Shape" Style="{StaticResource SynthComboBoxStyle}" Margin="2,0,2,2"
                                       SelectionChanged="Lfo3Shape_SelectionChanged"/>
                            <ctl:LfoDisplay Grid.Row="2" x:Name="Lfo3View" Height="32" Margin="2,2"/>
                            <UniformGrid Grid.Row="3" Columns="2">
                                <ctl:SynthKnob x:Name="Lfo3Rate"  Label="RATE"  Minimum="0.01" Maximum="30" Value="1" DefaultValue="1" ValueFormat="F2" Unit=" Hz" ValueChanged="Lfo3Knob_ValueChanged"/>
                                <ctl:SynthKnob x:Name="Lfo3Depth" Label="DEPTH" Minimum="0"    Maximum="1"  Value="1" DefaultValue="1" ValueFormat="P0"            ValueChanged="Lfo3Knob_ValueChanged"/>
                            </UniformGrid>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>

            <!-- ── MOD MATRIX / MASTER ─────────────────────────── -->
            <Border Grid.Column="1" Grid.Row="2" Style="{StaticResource SynthPanelBorder}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="// MOD MATRIX // MASTER" Style="{StaticResource HeaderTextStyle}" Margin="0,0,0,6"/>
                    <ctl:ModMatrixGrid Grid.Row="1" x:Name="ModMatrixView"/>
                    <UniformGrid Grid.Row="2" Columns="5" Margin="0,6,0,0">
                        <ctl:SynthKnob x:Name="Macro1Knob"     Label="M1"     Minimum="0" Maximum="1" Value="0"   DefaultValue="0"   ValueFormat="P0" ValueChanged="MacroKnob_ValueChanged"/>
                        <ctl:SynthKnob x:Name="Macro2Knob"     Label="M2"     Minimum="0" Maximum="1" Value="0"   DefaultValue="0"   ValueFormat="P0" ValueChanged="MacroKnob_ValueChanged"/>
                        <ctl:SynthKnob x:Name="Macro3Knob"     Label="M3"     Minimum="0" Maximum="1" Value="0"   DefaultValue="0"   ValueFormat="P0" ValueChanged="MacroKnob_ValueChanged"/>
                        <ctl:SynthKnob x:Name="Macro4Knob"     Label="M4"     Minimum="0" Maximum="1" Value="0"   DefaultValue="0"   ValueFormat="P0" ValueChanged="MacroKnob_ValueChanged"/>
                        <ctl:SynthKnob x:Name="MasterVolumeKnob" Label="MASTER" Minimum="0" Maximum="1" Value="0.8" DefaultValue="0.8" ValueFormat="P0" ValueChanged="MasterVolumeKnob_ValueChanged"/>
                    </UniformGrid>
                </Grid>
            </Border>
        </Grid>

        <!-- ═══ EFFECTS RACK ═════════════════════════════════════ -->
        <Border Grid.Row="2" Style="{StaticResource SynthPanelBorder}" Margin="6,0,6,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="// EFFECTS" Style="{StaticResource HeaderTextStyle}"
                           VerticalAlignment="Center" Margin="0,0,12,0"/>
                <StackPanel Grid.Column="1" x:Name="EffectsPanel" Orientation="Horizontal"/>
            </Grid>
        </Border>

        <!-- ═══ DEBUG LOG ═════════════════════════════════════════ -->
        <Border Grid.Row="3" Style="{StaticResource SynthPanelBorder}" Margin="6,0,6,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="// LOG" Style="{StaticResource HeaderTextStyle}"
                           VerticalAlignment="Center" Margin="0,0,12,0"/>
                <ScrollViewer Grid.Column="1" x:Name="LogScroller"
                              VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Hidden">
                    <TextBox x:Name="LogBox"
                             Background="Transparent"
                             Foreground="{StaticResource TextPrimaryBrush}"
                             FontFamily="Cascadia Mono" FontSize="10"
                             BorderThickness="0" IsReadOnly="True"
                             TextWrapping="NoWrap" AcceptsReturn="True"
                             VerticalScrollBarVisibility="Disabled"/>
                </ScrollViewer>
                <Button Grid.Column="2" Content="[ CLEAR ]" Style="{StaticResource SynthButtonStyle}"
                        VerticalAlignment="Center" Click="ClearLogBtn_Click"/>
            </Grid>
        </Border>

        <!-- ═══ PIANO KEYBOARD ════════════════════════════════════ -->
        <Border Grid.Row="4" Background="#FF010402" BorderBrush="#FF1A4D23" BorderThickness="0,1,0,0" Padding="8,4">
            <ctl:PianoKeyboard x:Name="Keyboard" StartNote="36" EndNote="96"/>
        </Border>

        <!-- ═══ STATUS BAR ════════════════════════════════════════ -->
        <Border Grid.Row="5" Background="#FF010402" BorderBrush="#FF1A4D23" BorderThickness="0,1,0,0">
            <Grid Margin="12,0">
                <TextBlock x:Name="StatusText" Text="&gt; SYSTEM READY"
                           Style="{StaticResource LabelTextStyle}" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock x:Name="VoicesText" Text="VOICES:0" Style="{StaticResource LabelTextStyle}" Margin="0,0,16,0"/>
                    <TextBlock x:Name="SrText"     Text="44100"    Style="{StaticResource LabelTextStyle}" Margin="0,0,16,0"/>
                    <Button x:Name="PanicBtn" Content="[ PANIC ]" Style="{StaticResource SynthButtonStyle}" Click="PanicBtn_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
