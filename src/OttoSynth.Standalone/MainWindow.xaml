<Window x:Class="OttoSynth.Standalone.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ctl="clr-namespace:OttoSynth.UI.Controls;assembly=OttoSynth.UI"
        xmlns:views="clr-namespace:OttoSynth.Standalone.Views"
        xmlns:uiviews="clr-namespace:OttoSynth.UI.Views;assembly=OttoSynth.UI"
        xmlns:ad="clr-namespace:AvalonDock;assembly=AvalonDock"
        xmlns:adl="clr-namespace:AvalonDock.Layout;assembly=AvalonDock"
        Title="OttoSynth v1.0.0-beta.1"
        Width="1280" Height="1000"
        MinWidth="1060" MinHeight="850"
        Background="{DynamicResource BackgroundPrimaryBrush}"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded"
        Closing="Window_Closing">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="54"/>   <!-- Header -->
            <RowDefinition Height="*"/>    <!-- DockingManager -->
            <RowDefinition Height="180"/>  <!-- Effects rack -->
            <RowDefinition Height="120"/>  <!-- Keyboard -->
            <RowDefinition Height="28"/>   <!-- Status Bar -->
        </Grid.RowDefinitions>

        <!-- ═══ HEADER ═══════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="{DynamicResource BackgroundDeepBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
            <Grid Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="&gt; OTTO" FontSize="22" FontWeight="Bold"
                               Foreground="{DynamicResource AccentPrimaryBrush}" FontFamily="Cascadia Mono">
                        <TextBlock.Effect>
                            <DropShadowEffect Color="#FF00FF41" BlurRadius="10" ShadowDepth="0" Opacity="0.8"/>
                        </TextBlock.Effect>
                    </TextBlock>
                    <TextBlock Text="SYNTH_" FontSize="22" FontWeight="Bold"
                               Foreground="{DynamicResource AccentAmberBrush}" FontFamily="Cascadia Mono" Margin="2,0,0,0">
                        <TextBlock.Effect>
                            <DropShadowEffect Color="#FFFFB000" BlurRadius="8" ShadowDepth="0" Opacity="0.6"/>
                        </TextBlock.Effect>
                    </TextBlock>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="Preset:" Style="{DynamicResource LabelTextStyle}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <ComboBox x:Name="PresetSelector" Width="180" Style="{DynamicResource SynthComboBoxStyle}"
                              SelectionChanged="PresetSelector_SelectionChanged"/>
                    <Button x:Name="LoadPresetBtn"   Content="Load"    Style="{DynamicResource SynthButtonStyle}" Margin="4,0,0,0" Click="LoadPresetBtn_Click"/>
                    <Button x:Name="SavePresetBtn"   Content="Save"    Style="{DynamicResource SynthButtonStyle}" Margin="4,0,0,0" Click="SavePresetBtn_Click"   ToolTip="Save current state as user preset (.otto)"/>
                    <Button x:Name="ImportPresetBtn" Content="Import…" Style="{DynamicResource SynthButtonStyle}" Margin="4,0,0,0" Click="ImportPresetBtn_Click" ToolTip="Import a .otto preset file"/>
                    <Button x:Name="ExportPresetBtn" Content="Export…" Style="{DynamicResource SynthButtonStyle}" Margin="4,0,0,0" Click="ExportPresetBtn_Click" ToolTip="Export current state as .otto file"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Theme:" Style="{DynamicResource LabelTextStyle}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <ComboBox x:Name="ThemeSelector" Width="72" Style="{DynamicResource SynthComboBoxStyle}"
                              SelectionChanged="ThemeSelector_SelectionChanged"/>
                    <TextBlock Text="MIDI:" Style="{DynamicResource LabelTextStyle}" VerticalAlignment="Center" Margin="12,0,8,0"/>
                    <ComboBox x:Name="MidiDeviceSelector" Width="200" Style="{DynamicResource SynthComboBoxStyle}"
                              SelectionChanged="MidiDeviceSelector_SelectionChanged"/>
                    <Button x:Name="RefreshMidiBtn" Content="[ ↻ ]" Style="{DynamicResource SynthButtonStyle}"
                            Margin="6,0,0,0" ToolTip="Re-scan MIDI devices" Click="RefreshMidiBtn_Click"/>
                    <Button x:Name="AudioSettingsBtn" Content="[ ⚙ ]" Style="{DynamicResource SynthButtonStyle}"
                            Margin="6,0,0,0" ToolTip="Audio settings (sample rate, buffer size)" Click="AudioSettingsBtn_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ DOCKING AREA ══════════════════════════════════════ -->
        <ad:DockingManager x:Name="DockManager" Grid.Row="1" Margin="4,4,4,0">
            <adl:LayoutRoot>
                <adl:LayoutPanel Orientation="Horizontal">

                    <!-- ── LEFT COLUMN (wider) ───────────────────── -->
                    <adl:LayoutPanel Orientation="Vertical" DockWidth="480">

                        <!-- OSC row — tallest -->
                        <adl:LayoutAnchorablePaneGroup DockHeight="320">
                            <adl:LayoutAnchorablePane>
                                <adl:LayoutAnchorable ContentId="Oscillators" Title="// OSCILLATORS" CanClose="False" CanHide="False">
                                    <uiviews:OscillatorsPanel x:Name="OscillatorsPanelView"/>
                                </adl:LayoutAnchorable>
                            </adl:LayoutAnchorablePane>
                        </adl:LayoutAnchorablePaneGroup>

                        <!-- Filter + Envelope -->
                        <adl:LayoutPanel Orientation="Horizontal" DockHeight="180">
                            <adl:LayoutAnchorablePaneGroup>
                                <adl:LayoutAnchorablePane>
                                    <adl:LayoutAnchorable ContentId="Filter" Title="// FILTER" CanClose="False" CanHide="False">
                                        <uiviews:FilterPanel x:Name="FilterPanelView"/>
                                    </adl:LayoutAnchorable>
                                </adl:LayoutAnchorablePane>
                            </adl:LayoutAnchorablePaneGroup>
                            <adl:LayoutAnchorablePaneGroup>
                                <adl:LayoutAnchorablePane>
                                    <adl:LayoutAnchorable ContentId="Envelope" Title="// ENVELOPES" CanClose="False" CanHide="False">
                                        <uiviews:EnvelopePanel x:Name="EnvelopePanelView"/>
                                    </adl:LayoutAnchorable>
                                </adl:LayoutAnchorablePane>
                            </adl:LayoutAnchorablePaneGroup>
                        </adl:LayoutPanel>

                        <!-- LFOs + ModMatrix -->
                        <adl:LayoutPanel Orientation="Horizontal" DockHeight="180">
                            <adl:LayoutAnchorablePaneGroup>
                                <adl:LayoutAnchorablePane>
                                    <adl:LayoutAnchorable ContentId="Lfos" Title="// LFOs" CanClose="False" CanHide="False">
                                        <uiviews:LfosPanel x:Name="LfosPanelView"/>
                                    </adl:LayoutAnchorable>
                                </adl:LayoutAnchorablePane>
                            </adl:LayoutAnchorablePaneGroup>
                            <adl:LayoutAnchorablePaneGroup>
                                <adl:LayoutAnchorablePane>
                                    <adl:LayoutAnchorable ContentId="ModMatrix" Title="// MOD MATRIX" CanClose="False" CanHide="False">
                                        <uiviews:ModMatrixPanel x:Name="ModMatrixPanelView"/>
                                    </adl:LayoutAnchorable>
                                </adl:LayoutAnchorablePane>
                            </adl:LayoutAnchorablePaneGroup>
                        </adl:LayoutPanel>

                        <!-- Arpeggiator + Step Sequencer -->
                        <adl:LayoutAnchorablePaneGroup DockHeight="200">
                            <adl:LayoutAnchorablePane>
                                <adl:LayoutAnchorable ContentId="ArpSeq" Title="// ARP / SEQ" CanClose="False" CanHide="False">
                                    <views:ArpSequencerPanel x:Name="ArpSequencerPanelView"/>
                                </adl:LayoutAnchorable>
                            </adl:LayoutAnchorablePane>
                        </adl:LayoutAnchorablePaneGroup>

                    </adl:LayoutPanel>

                    <!-- ── RIGHT COLUMN (narrower) ───────────────── -->
                    <adl:LayoutPanel Orientation="Vertical" DockWidth="240">

                        <!-- Analyzer -->
                        <adl:LayoutAnchorablePaneGroup DockHeight="240">
                            <adl:LayoutAnchorablePane>
                                <adl:LayoutAnchorable ContentId="Analyzer" Title="// ANALYZER" CanClose="False" CanHide="False">
                                    <views:AnalyzerPanel x:Name="AnalyzerPanelView"/>
                                </adl:LayoutAnchorable>
                            </adl:LayoutAnchorablePane>
                        </adl:LayoutAnchorablePaneGroup>

                        <!-- Preset Browser -->
                        <adl:LayoutAnchorablePaneGroup DockHeight="220">
                            <adl:LayoutAnchorablePane>
                                <adl:LayoutAnchorable ContentId="PresetBrowser" Title="// PRESETS" CanClose="False" CanHide="False">
                                    <uiviews:PresetBrowserPanel x:Name="PresetBrowserPanelView" Margin="4"/>
                                </adl:LayoutAnchorable>
                            </adl:LayoutAnchorablePane>
                        </adl:LayoutAnchorablePaneGroup>

                        <!-- Master -->
                        <adl:LayoutAnchorablePaneGroup DockHeight="220">
                            <adl:LayoutAnchorablePane>
                                <adl:LayoutAnchorable ContentId="Master" Title="// MASTER" CanClose="False" CanHide="False">
                                    <uiviews:MasterPanel x:Name="MasterPanelView"/>
                                </adl:LayoutAnchorable>
                            </adl:LayoutAnchorablePane>
                        </adl:LayoutAnchorablePaneGroup>

                    </adl:LayoutPanel>

                </adl:LayoutPanel>
            </adl:LayoutRoot>
        </ad:DockingManager>

        <!-- ═══ EFFECTS RACK ═════════════════════════════════════ -->
        <Border Grid.Row="2" Style="{DynamicResource SynthPanelBorder}" Margin="6,0,6,4">
            <views:EffectsRack x:Name="EffectsRackView"/>
        </Border>

        <!-- ═══ PIANO KEYBOARD ════════════════════════════════════ -->
        <Border Grid.Row="3" Background="{DynamicResource BackgroundDeepBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Padding="8,4">
            <ctl:PianoKeyboard x:Name="Keyboard" StartNote="36" EndNote="96"/>
        </Border>

        <!-- ═══ STATUS BAR ════════════════════════════════════════ -->
        <Border Grid.Row="4" Background="{DynamicResource BackgroundDeepBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
            <Grid Margin="12,0">
                <TextBlock x:Name="StatusText" Text="&gt; SYSTEM READY"
                           Style="{DynamicResource LabelTextStyle}" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock x:Name="VoicesText" Text="VOICES:0" Style="{DynamicResource LabelTextStyle}" Margin="0,0,16,0"/>
                    <TextBlock x:Name="SrText"     Text="44100"    Style="{DynamicResource LabelTextStyle}" Margin="0,0,16,0"/>
                    <Button x:Name="PanicBtn" Content="[ PANIC ]" Style="{DynamicResource SynthButtonStyle}" Click="PanicBtn_Click"/>
                </StackPanel>
            </Grid>
        </Border>

    </Grid>
</Window>
