<UserControl x:Class="OttoSynth.Standalone.Views.ArpSequencerPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
    <Grid Margin="6,4,6,4">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- ARP controls -->
            <RowDefinition Height="Auto"/> <!-- SEQ controls -->
            <RowDefinition Height="*"/>    <!-- Step grid -->
        </Grid.RowDefinitions>

        <!-- ARP section (header + controls built in code-behind) -->
        <StackPanel x:Name="ArpControlsPanel" Grid.Row="0"
                    Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,4"/>

        <!-- SEQ section (header + controls built in code-behind) -->
        <StackPanel x:Name="SeqControlsPanel" Grid.Row="1"
                    Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,4"/>

        <!-- Step grid: horizontally scrollable row of step cells -->
        <ScrollViewer Grid.Row="2"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Disabled">
            <StackPanel x:Name="StepsPanel" Orientation="Horizontal"/>
        </ScrollViewer>
    </Grid>
    </ScrollViewer>
</UserControl>
