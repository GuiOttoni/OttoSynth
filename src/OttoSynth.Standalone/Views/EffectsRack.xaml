<UserControl x:Class="OttoSynth.Standalone.Views.EffectsRack"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- header -->
            <RowDefinition Height="50"/>    <!-- slots strip -->
            <RowDefinition Height="*"/>     <!-- params panel -->
        </Grid.RowDefinitions>

        <!-- ── Header ─────────────────────────────────── -->
        <Grid Grid.Row="0" Margin="0,0,0,2">
            <TextBlock Text="// EFFECTS" Style="{DynamicResource HeaderTextStyle}" VerticalAlignment="Center"/>
            <Button x:Name="AddEffectBtn" Content="[ + ADD ]"
                    Style="{DynamicResource SynthButtonStyle}"
                    HorizontalAlignment="Right"
                    Click="AddEffectBtn_Click"/>
        </Grid>

        <!-- ── Slots strip ─────────────────────────────── -->
        <ScrollViewer Grid.Row="1"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Disabled">
            <StackPanel x:Name="SlotsPanel" Orientation="Horizontal" VerticalAlignment="Center"/>
        </ScrollViewer>

        <!-- ── Params panel ────────────────────────────── -->
        <ScrollViewer Grid.Row="2"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Disabled"
                      Margin="0,2,0,0">
            <StackPanel x:Name="ParamsPanel" Orientation="Horizontal"/>
        </ScrollViewer>
    </Grid>
    </ScrollViewer>
</UserControl>
