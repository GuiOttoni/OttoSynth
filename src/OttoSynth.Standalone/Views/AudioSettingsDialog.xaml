<Window x:Class="OttoSynth.Standalone.Views.AudioSettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="// AUDIO SETTINGS"
        Width="380" Height="260"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundPrimaryBrush}"
        Foreground="{DynamicResource TextPrimaryBrush}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="// AUDIO SETTINGS"
                   Style="{DynamicResource HeaderTextStyle}"/>

        <!-- Sample Rate -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Sample Rate" Style="{DynamicResource LabelTextStyle}" VerticalAlignment="Center"/>
            <ComboBox Grid.Column="1" x:Name="SampleRateBox" Style="{DynamicResource SynthComboBoxStyle}"
                      SelectionChanged="OnSettingChanged"/>
        </Grid>

        <!-- Buffer Size -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Buffer Size" Style="{DynamicResource LabelTextStyle}" VerticalAlignment="Center"/>
            <ComboBox Grid.Column="1" x:Name="BufferSizeBox" Style="{DynamicResource SynthComboBoxStyle}"
                      SelectionChanged="OnSettingChanged"/>
        </Grid>

        <!-- Latency display -->
        <Grid Grid.Row="6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Latency (approx.)" Style="{DynamicResource LabelTextStyle}" VerticalAlignment="Center"/>
            <TextBlock Grid.Column="1" x:Name="LatencyText"
                       Style="{DynamicResource ValueTextStyle}"
                       Foreground="{DynamicResource AccentPrimaryBrush}"
                       VerticalAlignment="Center"/>
        </Grid>

        <!-- Buttons -->
        <StackPanel Grid.Row="8" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="CANCEL" Style="{DynamicResource SynthButtonStyle}"
                    Margin="0,0,8,0" Click="OnCancel"/>
            <Button Content="APPLY" Style="{DynamicResource SynthButtonStyle}"
                    IsDefault="True" Click="OnApply"/>
        </StackPanel>
    </Grid>
</Window>
