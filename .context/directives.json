{
  "project": {
    "name": "OttoSynth",
    "description": "Sintetizador wavetable polifônico VST3 desenvolvido em C#/.NET",
    "type": "VST3 Audio Plugin",
    "language": "C#",
    "framework_version": ".NET 8.0+",
    "target_platforms": ["Windows"],
    "future_platforms": ["macOS", "Linux"],
    "inspirations": ["Vital", "Serum", "Helm"],
    "created": "2026-05-20"
  },

  "architecture": {
    "plugin_format": "VST3",
    "plugin_framework": "AudioPlugSharp",
    "gui_framework": "WPF",
    "pattern": "MVVM",
    "audio_thread_rules": [
      "NUNCA alocar memória (new) no audio thread",
      "NUNCA usar locks/mutex no audio thread",
      "Usar object pooling para todos os buffers",
      "Comunicação UI ↔ Audio via lock-free queues (Interlocked)",
      "Pré-alocar todos os arrays e buffers no construtor",
      "Evitar boxing/unboxing no hot path"
    ],
    "separation_of_concerns": {
      "OttoSynth.Core": "DSP engine puro — zero dependência de UI ou plugin framework",
      "OttoSynth.Plugin": "Wrapper VST3 via AudioPlugSharp — apenas bridge",
      "OttoSynth.UI": "Interface WPF — MVVM, sem lógica de áudio",
      "OttoSynth.Standalone": "App para desenvolvimento e testes sem DAW"
    }
  },

  "dsp_engine": {
    "sample_rate": 44100,
    "buffer_sizes": [64, 128, 256, 512, 1024],
    "bit_depth": "64-bit double (interno), 32-bit float (output VST3)",
    "channels": 2,

    "oscillators": {
      "count": 3,
      "type": "Wavetable",
      "wavetable_size": 2048,
      "max_wavetable_frames": 256,
      "interpolation": "Hermite (cúbica)",
      "anti_aliasing": "Mipmap de wavetable + PolyBLEP para formas clássicas",
      "unison_max_voices": 16,
      "unison_features": ["detune", "stereo_spread", "phase_randomization", "wavetable_spread"],
      "parameters": [
        { "name": "wavetable_position", "range": [0.0, 1.0], "default": 0.0 },
        { "name": "level", "range": [0.0, 1.0], "default": 0.8 },
        { "name": "pan", "range": [-1.0, 1.0], "default": 0.0 },
        { "name": "coarse_tune", "range": [-48, 48], "unit": "semitones", "default": 0 },
        { "name": "fine_tune", "range": [-100, 100], "unit": "cents", "default": 0 },
        { "name": "unison_voices", "range": [1, 16], "default": 1 },
        { "name": "unison_detune", "range": [0.0, 1.0], "default": 0.3 },
        { "name": "unison_spread", "range": [0.0, 1.0], "default": 0.5 },
        { "name": "phase", "range": [0.0, 1.0], "default": 0.0 }
      ]
    },

    "noise_oscillator": {
      "count": 1,
      "types": ["white", "pink", "sample_based"],
      "parameters": [
        { "name": "level", "range": [0.0, 1.0], "default": 0.0 },
        { "name": "type", "values": ["white", "pink"], "default": "white" }
      ]
    },

    "filters": {
      "count": 2,
      "types_priority": [
        { "name": "SVF", "slopes": ["12dB", "24dB"], "outputs": ["LP", "HP", "BP", "Notch"], "priority": "v1.0" },
        { "name": "MoogLadder", "slopes": ["24dB"], "outputs": ["LP"], "priority": "v1.1" },
        { "name": "Comb", "priority": "v1.2" },
        { "name": "Formant", "priority": "v1.2" }
      ],
      "routing_modes": ["serial", "parallel", "split"],
      "parameters": [
        { "name": "cutoff", "range": [20.0, 20000.0], "unit": "Hz", "default": 20000.0, "scale": "logarithmic" },
        { "name": "resonance", "range": [0.0, 1.0], "default": 0.0 },
        { "name": "drive", "range": [0.0, 1.0], "default": 0.0 },
        { "name": "type", "values": ["LP", "HP", "BP", "Notch"], "default": "LP" },
        { "name": "key_tracking", "range": [0.0, 1.0], "default": 0.0 }
      ]
    },

    "envelopes": {
      "count": 3,
      "type": "ADSR",
      "assignments_default": {
        "envelope_1": "amplitude",
        "envelope_2": "filter_cutoff",
        "envelope_3": "free (mod matrix)"
      },
      "parameters": [
        { "name": "attack", "range": [0.001, 10.0], "unit": "seconds", "default": 0.01, "scale": "logarithmic" },
        { "name": "decay", "range": [0.001, 10.0], "unit": "seconds", "default": 0.3, "scale": "logarithmic" },
        { "name": "sustain", "range": [0.0, 1.0], "default": 0.7 },
        { "name": "release", "range": [0.001, 10.0], "unit": "seconds", "default": 0.5, "scale": "logarithmic" },
        { "name": "attack_curve", "range": [-1.0, 1.0], "default": 0.0, "description": "-1=log, 0=linear, 1=exp" },
        { "name": "decay_curve", "range": [-1.0, 1.0], "default": 0.0 },
        { "name": "release_curve", "range": [-1.0, 1.0], "default": 0.0 }
      ]
    },

    "lfos": {
      "count": 3,
      "shapes": ["sine", "triangle", "saw_up", "saw_down", "square", "sample_hold", "custom"],
      "parameters": [
        { "name": "rate", "range": [0.01, 30.0], "unit": "Hz", "default": 1.0 },
        { "name": "sync", "values": ["free", "1/1", "1/2", "1/4", "1/8", "1/16", "1/32"], "default": "free" },
        { "name": "depth", "range": [0.0, 1.0], "default": 1.0 },
        { "name": "phase", "range": [0.0, 1.0], "default": 0.0 },
        { "name": "retrigger", "type": "bool", "default": true },
        { "name": "stereo_offset", "range": [0.0, 1.0], "default": 0.0 }
      ]
    },

    "modulation_matrix": {
      "max_routes": 32,
      "sources": [
        "envelope_1", "envelope_2", "envelope_3",
        "lfo_1", "lfo_2", "lfo_3",
        "velocity", "key_tracking", "mod_wheel",
        "aftertouch", "pitch_bend",
        "macro_1", "macro_2", "macro_3", "macro_4",
        "random", "note_number"
      ],
      "destination_categories": [
        "oscillator (pitch, wavetable_position, level, pan, unison_detune)",
        "filter (cutoff, resonance, drive)",
        "envelope (attack, decay, sustain, release)",
        "lfo (rate, depth, phase)",
        "effects (any parameter)",
        "global (master_volume, master_pan)"
      ],
      "route_properties": {
        "amount": { "range": [-1.0, 1.0], "default": 0.0, "description": "Bipolar modulation amount" },
        "curve": { "range": [-1.0, 1.0], "default": 0.0, "description": "Response curve remapping" },
        "bypass": { "type": "bool", "default": false }
      }
    },

    "effects": {
      "reorderable": true,
      "per_effect_bypass": true,
      "effects_list": [
        { "name": "Distortion", "priority": "v1.0", "types": ["overdrive", "waveshape", "bitcrush", "foldback"] },
        { "name": "Filter", "priority": "v1.0", "description": "Filtro global independente" },
        { "name": "Delay", "priority": "v1.0", "types": ["stereo", "ping_pong", "synced"] },
        { "name": "Reverb", "priority": "v1.0", "algorithm": "algorithmic (FDN)" },
        { "name": "Chorus", "priority": "v1.1" },
        { "name": "Phaser", "priority": "v1.1" },
        { "name": "Flanger", "priority": "v1.1" },
        { "name": "EQ", "priority": "v1.1", "bands": 3 },
        { "name": "Compressor", "priority": "v1.2" }
      ]
    }
  },

  "voice_management": {
    "max_polyphony": 32,
    "default_polyphony": 16,
    "allocation_algorithm": "round_robin",
    "stealing_algorithm": "oldest_released_first",
    "stealing_fadeout_ms": 3,
    "voice_states": ["idle", "active", "releasing", "stealing"],
    "mono_mode": {
      "enabled": false,
      "legato": true,
      "portamento_time_ms": 50
    }
  },

  "midi": {
    "supported_messages": [
      "note_on", "note_off", "pitch_bend", "mod_wheel",
      "aftertouch", "control_change", "program_change"
    ],
    "pitch_bend_range_semitones": 2,
    "velocity_curve": "linear",
    "formulas": {
      "midi_to_freq": "440.0 * Math.Pow(2.0, (noteNumber - 69) / 12.0)",
      "pitch_bend_14bit": "(msb << 7) | lsb",
      "pitch_bend_to_semitones": "((bendValue - 8192) / 8192.0) * bendRangeSemitones",
      "freq_with_bend": "baseFreq * Math.Pow(2.0, bendSemitones / 12.0)"
    }
  },

  "gui": {
    "framework": "WPF",
    "pattern": "MVVM",
    "theme": "dark",
    "default_size": { "width": 1200, "height": 800 },
    "dpi_aware": true,
    "resizable": true,
    "color_palette": {
      "background_primary": "#0D0D0D",
      "background_secondary": "#1A1A2E",
      "background_panel": "#16213E",
      "accent_primary": "#00D4FF",
      "accent_secondary": "#7B2FBE",
      "accent_tertiary": "#E94560",
      "text_primary": "#FFFFFF",
      "text_secondary": "#A0A0B0",
      "knob_track": "#2A2A3E",
      "knob_active": "#00D4FF",
      "waveform_color": "#00FF88",
      "grid_lines": "#1E1E30"
    },
    "custom_controls": [
      "SynthKnob",
      "SynthSlider",
      "WaveformDisplay",
      "SpectrumAnalyzer",
      "WavetableView3D",
      "EnvelopeEditor",
      "LFODisplay",
      "ModMatrixGrid",
      "PianoKeyboard",
      "PresetBrowser",
      "EffectSlot"
    ],
    "animations": {
      "waveform_fps": 60,
      "spectrum_fps": 30,
      "knob_smoothing": true,
      "transition_duration_ms": 150
    }
  },

  "presets": {
    "format": "JSON",
    "extension": ".ottopreset",
    "directory": "%APPDATA%/OttoSynth/Presets/",
    "categories": ["Bass", "Lead", "Pad", "Pluck", "Keys", "Strings", "FX", "Drum", "Sequence", "Ambient"],
    "metadata_fields": ["name", "author", "category", "tags", "description", "version", "created_date"],
    "factory_presets_count_target": 50
  },

  "coding_standards": {
    "naming": {
      "classes": "PascalCase",
      "methods": "PascalCase",
      "properties": "PascalCase",
      "private_fields": "_camelCase",
      "parameters": "camelCase",
      "constants": "PascalCase",
      "interfaces": "IPascalCase",
      "enums": "PascalCase"
    },
    "documentation": {
      "language": "English (code), Portuguese (comments where needed)",
      "xml_docs": "Required for all public methods and classes",
      "inline_comments": "For complex DSP algorithms only"
    },
    "testing": {
      "framework": "xUnit",
      "naming_convention": "MethodName_Scenario_ExpectedResult",
      "coverage_target": "80% for Core, 50% for Plugin",
      "dsp_testing": "Compare output buffers against known-good reference data"
    },
    "performance_rules": [
      "No heap allocations in Process() methods",
      "Use Span<T> for buffer passing",
      "Use MathF instead of Math for float operations",
      "Inline small methods with [MethodImpl(AggressiveInlining)]",
      "Prefer stackalloc for small temporary buffers",
      "Cache frequently used values (e.g., 1/sampleRate)"
    ]
  },

  "development_phases": {
    "phase_1_foundation": {
      "name": "Fundação — Motor DSP Básico",
      "priority": "CRITICAL",
      "deliverables": [
        "Solution structure + projetos",
        "SynthEngine básico com 1 oscilador (wavetable simples)",
        "ADSR Envelope (amplitude)",
        "Voice Manager (polifonia básica — 8 vozes)",
        "MIDI input (Note On/Off)",
        "Standalone app com NAudio para testar áudio",
        "Testes unitários para oscilador e envelope"
      ]
    },
    "phase_2_synthesis": {
      "name": "Síntese Completa",
      "priority": "HIGH",
      "deliverables": [
        "3 osciladores wavetable com morphing",
        "Wavetable loading (arquivos .wav)",
        "Filtro SVF (LP, HP, BP, Notch)",
        "3 Envelopes ADSR com curvas ajustáveis",
        "3 LFOs",
        "Unison (detune, spread, phase)",
        "Noise oscillator",
        "Anti-aliasing (mipmap wavetable)",
        "Pitch bend e mod wheel"
      ]
    },
    "phase_3_modulation": {
      "name": "Sistema de Modulação",
      "priority": "HIGH",
      "deliverables": [
        "Modulation Matrix completa",
        "Mod sources: Envelopes, LFOs, Velocity, KeyTrack, Macros",
        "Drag-and-drop routing na UI",
        "Mod remap curves",
        "Second filter + routing modes"
      ]
    },
    "phase_4_gui": {
      "name": "Interface WPF Completa",
      "priority": "HIGH",
      "deliverables": [
        "Custom controls (Knob, Slider, WaveformDisplay)",
        "Layout principal com todas as seções",
        "Tema escuro com cores vibrantes",
        "Visualizações em tempo real (waveform, spectrum)",
        "Envelope editor visual (ADSR drag)",
        "Piano keyboard virtual",
        "DPI scaling"
      ]
    },
    "phase_5_vst3": {
      "name": "Integração VST3",
      "priority": "HIGH",
      "deliverables": [
        "AudioPlugSharp integration",
        "Parameter mapping VST3",
        "GUI embedding in DAW",
        "Testes em Ableton, FL Studio, Reaper",
        "VST3 validation"
      ]
    },
    "phase_6_effects": {
      "name": "Effects Rack",
      "priority": "MEDIUM",
      "deliverables": [
        "Distortion (waveshape + bitcrush)",
        "Delay (stereo, synced)",
        "Reverb (algorithmic FDN)",
        "Effects chain reordenável",
        "Per-effect bypass e mix"
      ]
    },
    "phase_7_presets": {
      "name": "Sistema de Presets",
      "priority": "MEDIUM",
      "deliverables": [
        "Serialização/deserialização JSON",
        "Preset browser UI",
        "50 factory presets",
        "Import/export",
        "Init preset"
      ]
    },
    "phase_8_polish": {
      "name": "Polimento e Otimização",
      "priority": "MEDIUM",
      "deliverables": [
        "Performance profiling e otimização",
        "Wavetable editor",
        "Moog Ladder filter",
        "Chorus, Phaser, Flanger effects",
        "EQ e Compressor",
        "Documentação do usuário",
        "Testes extensivos de compatibilidade"
      ]
    }
  },

  "critical_formulas": {
    "midi_note_to_frequency": "440.0 * Math.Pow(2.0, (note - 69) / 12.0)",
    "phase_increment": "frequency / sampleRate",
    "wavetable_read_index": "phase * wavetableSize",
    "hermite_interpolation": "a * t^3 + b * t^2 + c * t + d (where a,b,c,d from 4 surrounding samples)",
    "poly_blep": "if (t < dt) { t /= dt; return t+t - t*t - 1; } else if (t > 1-dt) { t = (t-1)/dt; return t*t + t+t + 1; } return 0;",
    "svf_g": "Math.Tan(Math.PI * cutoff / sampleRate)",
    "adsr_exponential_curve": "target + (current - target) * Math.Exp(-1.0 / (timeConstant * sampleRate))",
    "db_to_linear": "Math.Pow(10.0, dB / 20.0)",
    "linear_to_db": "20.0 * Math.Log10(linear)",
    "pan_law_equal_power": "leftGain = Math.Cos(pan * PI/4), rightGain = Math.Sin(pan * PI/4)"
  },

  "important_notes": [
    "AudioPlugSharp usa C++/CLI bridge — o .vst3 é um wrapper que carrega o assembly C#",
    "WPF só funciona em Windows — para Mac futuro, considerar SkiaSharp ou MAUI",
    "O audio thread do VST3 é chamado pelo host (DAW) — não criar threads próprias para áudio",
    "Todos os parâmetros VST3 devem ser normalizados [0, 1] — denormalização acontece no engine",
    "Testar SEMPRE com buffer sizes diferentes (64, 128, 256, 512, 1024)",
    "O sample rate é definido pelo host e pode mudar — não hardcodar 44100",
    "Usar double para cálculos internos DSP, converter para float apenas na saída",
    "Wavetables devem ser potência de 2 (1024, 2048, 4096) para bit-masking eficiente"
  ]
}
